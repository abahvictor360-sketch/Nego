# Copy this file to .env and fill in your values

# PostgreSQL connection string
# For Docker (local dev):  postgresql://nego:nego_dev_password@localhost:5432/negodb
# For Neon (cloud):        postgresql://<user>:<password>@<host>.neon.tech/<db>?sslmode=require
DATABASE_URL="postgresql://nego:nego_dev_password@localhost:5432/negodb"

# Express server port
PORT=3001

NODE_ENV=development

# Used to HMAC-sign checkout URLs — generate with: openssl rand -hex 32
CHECKOUT_SECRET=""

# OpenAI API key
OPENAI_API_KEY=""

# Default WooCommerce store URL (can be overridden per-request via storeUrl body param)
DEFAULT_STORE_URL="https://your-store.com"
